{% extends "layouts/admin.twig" %}
    {% block content %}

        <div class="main-content">
            <header class="top-bar">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="mobileToggle">
                            <i class="bi bi-list"></i>
                        </button>
                        <h5 class="mb-0">Publicação Web</h5>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="dropdown">
                            <button class="btn btn-sm position-relative" id="notificationsBtn" data-bs-toggle="dropdown">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end notifications-dropdown" id="notificationsDropdown">
                                <li class="dropdown-header">Notificações (3)<button class="btn btn-sm float-end" onclick="clearNotifications()"><i class="bi bi-x"></i></button></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-car-front text-primary"></i><div><strong>Novo veículo adicionado</strong><p>Toyota Corolla 2024</p><small class="text-muted">há 2 minutos</small></div></div></a></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-check-circle text-success"></i><div><strong>Venda realizada</strong><p>Honda Civic - 95.000.000</p><small class="text-muted">há 15 minutos</small></div></div></a></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-exclamation-circle text-warning"></i><div><strong>Documento vencido</strong><p>Seguro do veículo #12345</p><small class="text-muted">há 1 hora</small></div></div></a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-center small" href="#">Ver todas as notificações</a></li>
                            </ul>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-sm" id="userBtn" data-bs-toggle="dropdown">
                                <img src="https://via.placeholder.com/32" class="rounded-circle" alt="User">
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="perfil.html"><i class="bi bi-person"></i> Meu Perfil</a></li>
                                <li><a class="dropdown-item" href="configuracoes.html"><i class="bi bi-gear"></i> Configurações</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" onclick="logout()"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </header>

            <main class="page-content">
                <div class="container-fluid">
                    <div class="row mb-4">
                        <div class="col-12">
                            <h2>Publicação Web</h2>
                            <p class="text-muted">Gerencie a publicação de seus veículos no site público</p>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-primary">
                                            <i class="bi bi-globe"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Publicados</h6>
                                            <h3 class="mb-0">18</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-warning">
                                            <i class="bi bi-eye"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Visualizações</h6>
                                            <h3 class="mb-0">1,240</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card stat-card">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="stat-icon bg-success">
                                            <i class="bi bi-heart"></i>
                                        </div>
                                        <div class="ms-3">
                                            <h6 class="text-muted mb-0">Favoritos</h6>
                                            <h3 class="mb-0">89</h3>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Published Vehicles -->
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">Veículos Publicados</h5>
                            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#publishModal">
                                <i class="bi bi-plus-circle"></i> Publicar Veículo
                            </button>
                        </div>
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Modelo</th>
                                        <th>Status</th>
                                        <th>Visualizações</th>
                                        <th>Data de Publicação</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Toyota Corolla 2024</td>
                                        <td><span class="badge bg-success">Ativo</span></td>
                                        <td>245</td>
                                        <td>10/02/2024</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#publishModal">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" onclick="unpublishVehicle(1)">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Honda Civic 2023</td>
                                        <td><span class="badge bg-success">Ativo</span></td>
                                        <td>189</td>
                                        <td>09/02/2024</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#publishModal">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" onclick="unpublishVehicle(2)">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
   

    <!-- Publish Modal -->
    <div class="modal fade" id="publishModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Publicar Veículo na Web</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="publishForm">
                        <div class="mb-3">
                            <label class="form-label">Selecione o Veículo</label>
                            <select class="form-select" required>
                                <option value="">Escolha um veículo</option>
                                <option value="1">Toyota Corolla 2024</option>
                                <option value="2">Honda Civic 2023</option>
                                <option value="3">Fiat Argo 2022</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Destacar na Página Inicial?</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="highlight">
                                <label class="form-check-label" for="highlight">
                                    Sim, destacar este veículo
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Descrição para Web</label>
                            <textarea class="form-control" rows="4" placeholder="Descrição que aparecerá no site..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Galeria de Fotos</label>
                            <input type="file" class="form-control" multiple accept="image/*">
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="agree" checked>
                            <label class="form-check-label" for="agree">
                                Este veículo está disponível para venda
                            </label>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="publishVehicle()">Publicar</button>
                </div>
            </div>
        </div>
    </div>

    {% endblock %}