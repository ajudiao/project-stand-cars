<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações - AutoVendas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="../css/style.css">
</head>

<body>
    <div class="wrapper">
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <button id="sidebarToggle" class="btn-toggle-sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <h4 class="mb-0 brand-name">AutoVendas</h4>
            </div>

            <ul class="sidebar-menu">
                <li><a href="index.html" class="nav-link" data-page="dashboard"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a></li>
                <li><a href="veiculos.html" class="nav-link" data-page="veiculos"><i class="bi bi-car-front"></i><span>Veículos</span></a></li>
                <li><a href="clientes.html" class="nav-link" data-page="clientes"><i class="bi bi-people-fill"></i><span>Clientes</span></a></li>
                <li><a href="vendas.html" class="nav-link" data-page="vendas"><i class="bi bi-graph-up"></i><span>Vendas</span></a></li>
                <li><a href="relatorios.html" class="nav-link" data-page="relatorios"><i class="bi bi-file-earmark-pdf"></i><span>Relatórios</span></a></li>
                <li><a href="publicacao.html" class="nav-link" data-page="publicacao"><i class="bi bi-globe"></i><span>Publicação Web</span></a></li>
                <li class="divider"></li>
                <li><a href="perfil.html" class="nav-link" data-page="perfil"><i class="bi bi-person-circle"></i><span>Meu Perfil</span></a></li>
                <li><a href="configuracoes.html" class="nav-link active" data-page="configuracoes"><i class="bi bi-gear"></i><span>Configurações da Conta</span></a></li>
                <li><a href="configuracoes-site.html" class="nav-link" data-page="configuracoes-site"><i class="bi bi-globe-americas"></i><span>Configurações do Site</span></a></li>
                <li><a href="#" class="nav-link" onclick="logout()"><i class="bi bi-box-arrow-right"></i><span>Sair</span></a></li>
            </ul>
        </nav>

        <div class="main-content">
            <header class="top-bar">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-sm btn-outline-secondary d-lg-none" id="mobileToggle">
                            <i class="bi bi-list"></i>
                        </button>
                        <h5 class="mb-0">Configurações</h5>
                    </div>

                    <div class="d-flex align-items-center gap-3">
                        <div class="dropdown">
                            <button class="btn btn-sm position-relative" id="notificationsBtn" data-bs-toggle="dropdown">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end notifications-dropdown" id="notificationsDropdown">
                                <li class="dropdown-header">Notificações (3)<button class="btn btn-sm float-end" onclick="clearNotifications()"><i class="bi bi-x"></i></button></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-car-front text-primary"></i><div><strong>Novo veículo adicionado</strong><p>Toyota Corolla 2024</p><small class="text-muted">há 2 minutos</small></div></div></a></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-check-circle text-success"></i><div><strong>Venda realizada</strong><p>Honda Civic - R$ 95.000</p><small class="text-muted">há 15 minutos</small></div></div></a></li>
                                <li><a class="dropdown-item" href="#"><div class="notification-item"><i class="bi bi-exclamation-circle text-warning"></i><div><strong>Documento vencido</strong><p>Seguro do veículo #12345</p><small class="text-muted">há 1 hora</small></div></div></a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-center small" href="#">Ver todas as notificações</a></li>
                            </ul>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-sm" id="userBtn" data-bs-toggle="dropdown">
                                <img src="https://via.placeholder.com/32" class="rounded-circle" alt="User">
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="perfil.html"><i class="bi bi-person"></i> Meu Perfil</a></li>
                                <li><a class="dropdown-item" href="configuracoes.html"><i class="bi bi-gear"></i> Configurações</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#" onclick="logout()"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </header>

            <main class="page-content">
                <div class="container-fluid">
                    <div class="row mb-4">
                        <div class="col-12">
                            <h2>Configurações</h2>
                            <p class="text-muted">Gerencie as configurações do seu sistema</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <!-- Settings Navigation -->
                        <div class="col-lg-3">
                            <div class="list-group">
                                <a href="#general" class="list-group-item list-group-item-action active" data-bs-toggle="list">
                                    <i class="bi bi-gear"></i> Geral
                                </a>
                                <a href="#appearance" class="list-group-item list-group-item-action" data-bs-toggle="list">
                                    <i class="bi bi-palette"></i> Aparência
                                </a>
                                <a href="#notifications" class="list-group-item list-group-item-action" data-bs-toggle="list">
                                    <i class="bi bi-bell"></i> Notificações
                                </a>
                                <a href="#integrations" class="list-group-item list-group-item-action" data-bs-toggle="list">
                                    <i class="bi bi-plug"></i> Integrações
                                </a>
                                <a href="#backup" class="list-group-item list-group-item-action" data-bs-toggle="list">
                                    <i class="bi bi-cloud-check"></i> Backup
                                </a>
                            </div>
                        </div>

                        <!-- Settings Content -->
                        <div class="col-lg-9">
                            <!-- General Settings -->
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-gear"></i> Configurações Gerais
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-4">
                                        <label class="form-label">Idioma</label>
                                        <select class="form-select" onchange="saveSetting('language', this.value)">
                                            <option value="pt" selected>Português (Brasil)</option>
                                            <option value="en">English</option>
                                            <option value="es">Español</option>
                                        </select>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label">Moeda</label>
                                        <select class="form-select" onchange="saveSetting('currency', this.value)">
                                            <option value="BRL" selected>Real (R$)</option>
                                            <option value="USD">Dólar (US$)</option>
                                            <option value="EUR">Euro (€)</option>
                                        </select>
                                    </div>
                                    <div class="mb-4">
                                        <label class="form-label">Timezone</label>
                                        <select class="form-select" onchange="saveSetting('timezone', this.value)">
                                            <option value="America/Sao_Paulo" selected>Brasília (UTC-3)</option>
                                            <option value="America/New_York">Nova York (UTC-5)</option>
                                            <option value="Europe/London">Londres (UTC+0)</option>
                                        </select>
                                    </div>
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" id="maintenanceMode" onchange="saveSetting('maintenance', this.checked)">
                                        <label class="form-check-label" for="maintenanceMode">
                                            Modo de Manutenção
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Appearance Settings -->
                            <div class="card mt-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-palette"></i> Aparência
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-4">
                                        <label class="form-label">Tema</label>
                                        <div class="btn-group w-100" role="group">
                                            <input type="radio" class="btn-check" name="theme" id="light" value="light" onchange="saveSetting('theme', this.value)">
                                            <label class="btn btn-outline-secondary" for="light">
                                                <i class="bi bi-sun"></i> Claro
                                            </label>

                                            <input type="radio" class="btn-check" name="theme" id="dark" value="dark" onchange="saveSetting('theme', this.value)">
                                            <label class="btn btn-outline-secondary" for="dark">
                                                <i class="bi bi-moon"></i> Escuro
                                            </label>

                                            <input type="radio" class="btn-check" name="theme" id="auto" value="auto" checked onchange="saveSetting('theme', this.value)">
                                            <label class="btn btn-outline-secondary" for="auto">
                                                <i class="bi bi-circle-half"></i> Automático
                                            </label>
                                        </div>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="compactMode" onchange="saveSetting('compactMode', this.checked)">
                                        <label class="form-check-label" for="compactMode">
                                            Modo Compacto (reduz espaçamento)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Notification Settings -->
                            <div class="card mt-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-bell"></i> Notificações
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="newVehicles" checked onchange="saveSetting('notif_vehicles', this.checked)">
                                        <label class="form-check-label" for="newVehicles">
                                            Novo veículo adicionado
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="newSales" checked onchange="saveSetting('notif_sales', this.checked)">
                                        <label class="form-check-label" for="newSales">
                                            Nova venda realizada
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="newClients" checked onchange="saveSetting('notif_clients', this.checked)">
                                        <label class="form-check-label" for="newClients">
                                            Novo cliente cadastrado
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" id="emailNotif" checked onchange="saveSetting('email_notif', this.checked)">
                                        <label class="form-check-label" for="emailNotif">
                                            Receber notificações por email
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Integration Settings -->
                            <div class="card mt-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-plug"></i> Integrações
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6>WhatsApp</h6>
                                                <small class="text-muted">Integre WhatsApp para melhor comunicação</small>
                                            </div>
                                            <button class="btn btn-outline-primary btn-sm">Conectar</button>
                                        </div>
                                    </div>
                                    <hr>
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6>Email Marketing</h6>
                                                <small class="text-muted">Campanhas de email para clientes</small>
                                            </div>
                                            <button class="btn btn-outline-primary btn-sm">Conectar</button>
                                        </div>
                                    </div>
                                    <hr>
                                    <div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6>Google Analytics</h6>
                                                <small class="text-muted">Rastreie visitantes e conversões</small>
                                            </div>
                                            <button class="btn btn-outline-primary btn-sm">Conectar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Backup Settings -->
                            <div class="card mt-4">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-cloud-check"></i> Backup e Dados
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-4">
                                        <h6>Último Backup</h6>
                                        <p class="text-muted">15/02/2024 às 14:30</p>
                                        <button class="btn btn-primary btn-sm" onclick="backupNow()">
                                            <i class="bi bi-cloud-upload"></i> Fazer Backup Agora
                                        </button>
                                    </div>
                                    <hr>
                                    <div>
                                        <h6>Exportar Dados</h6>
                                        <p class="text-muted">Exporte todos os seus dados em CSV</p>
                                        <button class="btn btn-secondary btn-sm" onclick="exportData()">
                                            <i class="bi bi-download"></i> Exportar
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Danger Zone -->
                            <div class="card mt-4 border-danger">
                                <div class="card-header bg-danger text-white">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-exclamation-triangle"></i> Zona de Perigo
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted">Ações irreversíveis. Use com cuidado!</p>
                                    <button class="btn btn-outline-danger btn-sm" onclick="deleteAccount()">
                                        <i class="bi bi-trash"></i> Excluir Conta
                                    </button>
                                </div>
                            </div>

                            <!-- Save Button -->
                            <div class="mt-4">
                                <button class="btn btn-primary" onclick="saveAllSettings()">
                                    <i class="bi bi-check-circle"></i> Salvar Configurações
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/app.js"></script>
</body>

</html>
