<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Painel Admin{% endblock %}</title>

    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
</head>
<body>

<header>
    <h2>Painel Administrativo</h2>
</header>

<div style="display:flex">

    <aside style="width:200px;">
        <nav>
            <ul>
                <li><a href="{{ url('admin/dashboard') }}">Dashboard</a></li>
                <li><a href="{{ url('admin/cars') }}">Carros</a></li>
                <li><a href="{{ url('admin/sales') }}">Vendas</a></li>
                <li><a href="{{ url('admin/reports') }}">Relatórios</a></li>
            </ul>
        </nav>
    </aside>

    <main style="flex:1;">
        {% block content %}{% endblock %}
    </main>

</div>

</body>
</html>